#!/bin/bash
set -e

echo "=== DNS Configuration Restore Script ==="

# 1. Удаление кастомной конфигурации systemd-resolved
echo "[1/4] Removing custom script configurations..."
sudo rm -f /etc/systemd/resolved.conf.d/dot-custom.conf

# 2. Восстановление стандартной символической ссылки resolv.conf
echo "[2/4] Restoring standard resolv.conf symlink..."
sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf

# 3. Сбор сетевых данных текущей VPS для универсальности
echo "[3/4] Gathering network facts and updating Netplan..."

# Находим основной сетевой интерфейс (например, eth0 или ens18)
IFACE=$(ip route | grep default | awk '{print $5}' | head -n 1)

if [ -z "$IFACE" ]; then
    echo "Error: Default network interface not found!"
    exit 1
fi

# Собираем текущие "заводские" параметры сети
IP_ADDR=$(ip addr show "$IFACE" | grep "inet " | awk '{print $2}' | head -n 1)
GATEWAY=$(ip route | grep default | awk '{print $3}' | head -n 1)
MAC_ADDR=$(ip link show "$IFACE" | grep "link/ether" | awk '{print $2}' | head -n 1)

NETPLAN_FILE=$(ls /etc/netplan/*.yaml | head -n 1)

if [ -n "$NETPLAN_FILE" ]; then
    echo "Updating file: $NETPLAN_FILE ($IFACE)"
    
    # Делаем бэкап
    sudo cp "$NETPLAN_FILE" "${NETPLAN_FILE}.bak"
    
    # Генерируем чистый, идеальный YAML под текущую машину
    sudo tee "$NETPLAN_FILE" > /dev/null <<EOT
network:
  version: 2
  ethernets:
    $IFACE:
      match:
        macaddress: "$MAC_ADDR"
      addresses:
      - "$IP_ADDR"
      nameservers:
        addresses:
        - 1.1.1.1
        - 1.0.0.1
      set-name: "$IFACE"
      routes:
      - to: "default"
        via: "$GATEWAY"
EOT
else
    echo "Warning: No Netplan files found."
fi

# 4. Применение настроек сети
echo "[4/4] Applying network settings..."
sudo netplan apply
sudo systemctl daemon-reload
sudo systemctl restart systemd-networkd
sudo systemctl restart systemd-resolved

# Проверка итогового статуса
echo -e "\n=== Verification ==="
resolvectl status "$IFACE" 2>/dev/null || resolvectl status
