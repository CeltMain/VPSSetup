#!/bin/bash
set -e

echo "=== Начало восстановления сетевых настроек ==="

# 1. Удаление кастомной конфигурации systemd-resolved
echo "[1/5] Удаление файлов конфигурации скрипта..."
sudo rm -f /etc/systemd/resolved.conf.d/dot-custom.conf

# 2. Восстановление стандартной символической ссылки resolv.conf
echo "[2/5] Восстановление стандартного resolv.conf..."
sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf

# 3. Автоматический поиск файла Netplan и замена старого DNS на Cloudflare
echo "[3/5] Поиск и обновление конфигурации Netplan..."
NETPLAN_FILE=$(ls /etc/netplan/*.yaml | head -n 1)

if [ -n "$NETPLAN_FILE" ]; then
    echo "Найден файл конфигурации: $NETPLAN_FILE"
    # Удаляем старый IP Яндекса (или любой другой) и аккуратно вставляем Cloudflare
    sudo sed -i '/nameservers:/,/addresses:/ { /-[[:space:]]/d }' "$NETPLAN_FILE"
    sudo sed -i '/addresses:/a \        - 1.1.1.1\n        - 1.0.0.1' "$NETPLAN_FILE"
    # Убираем возможные пустые дубликаты строк, если скрипт запускается повторно
    sudo sed -i '/- 1.1.1.1/{N;/- 1.0.0.1/!D}' "$NETPLAN_FILE"
else
    echo "Предупреждение: Файлы Netplan не найдены."
fi

# 4. Применение сетевых настроек
echo "[4/5] Применение параметров сети..."
sudo netplan apply
sudo systemctl daemon-reload
sudo systemctl restart systemd-networkd
sudo systemctl restart systemd-resolved

# 5. Проверка статуса
echo -e "\n[5/5] Проверка итогового статуса сети:"
echo "----------------------------------------"
# Автоопределение активного интерфейса
MAIN_INT=$(ip route | grep default | awk '{print $5}' | head -n 1)
if [ -n "$MAIN_INT" ]; then
    resolvectl status "$MAIN_INT"
else
    resolvectl status
fi
echo "----------------------------------------"
echo "=== Восстановление успешно завершено! ==="
