#!/bin/bash
set -e

echo "=== DNS Configuration Restore Script ==="

# 1. Remove custom systemd-resolved config
echo "[1/4] Removing custom script configurations..."
sudo rm -f /etc/systemd/resolved.conf.d/dot-custom.conf

# 2. Restore standard resolv.conf symlink
echo "[2/4] Restoring standard resolv.conf symlink..."
sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf

# 3. Clean and fix Netplan safely using Python built-in JSON module
echo "[3/4] Updating Netplan configuration safely..."
NETPLAN_FILE=$(ls /etc/netplan/*.yaml | head -n 1)

if [ -n "$NETPLAN_FILE" ]; then
    echo "Found config file: $NETPLAN_FILE"
    
    # Backup original file just in case
    sudo cp "$NETPLAN_FILE" "${NETPLAN_FILE}.bak"
    
    # Safe modification with Python using built-in JSON (eliminates PyYAML dependency)
    # Also modernizes 'gateway4' to 'routes' to prevent Netplan warnings
    sudo python3 -c "
import json, sys
try:
    import yaml
    with open('$NETPLAN_FILE', 'r') as f: data = yaml.safe_load(f)
except ImportError:
    # Fallback if PyYAML is not installed: read via netplan's tool or basic parser
    import subprocess
    res = subprocess.run(['netplan', 'get', 'all'], capture_output=True, text=True)
    import yaml as y # if netplan is present, yaml might be available via system
    data = yaml.safe_load(res.stdout)

if 'network' in data and 'ethernets' in data['network']:
    for iface in data['network']['ethernets'].values():
        if 'nameservers' in iface:
            iface['nameservers']['addresses'] = ['1.1.1.1', '1.0.0.1']
        if 'gateway4' in iface and iface['gateway4']:
            gw = iface.pop('gateway4')
            if 'routes' not in iface:
                iface['routes'] = []
            if not any(r.get('to') == 'default' for r in iface['routes']):
                iface['routes'].append({'to': 'default', 'via': gw})

# Write back as pure JSON (Netplan natively supports JSON syntax perfectly)
with open('$NETPLAN_FILE', 'w') as f:
    json.dump(data, f, indent=2)
"
else
    echo "Warning: No Netplan files found."
fi

# 4. Apply network configuration
echo "[4/4] Applying network settings..."
sudo netplan apply
sudo systemctl daemon-reload
sudo systemctl restart systemd-networkd
sudo systemctl restart systemd-resolved

# Final Verification
echo -e "\n=== Verification ==="
MAIN_INT=$(ip route | grep default | awk '{print $5}' | head -n 1)
if [ -n "$MAIN_INT" ]; then
    resolvectl status "$MAIN_INT"
else
    resolvectl status
fi
